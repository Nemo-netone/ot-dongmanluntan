# Backend runtime
PORT=8090
DB_TYPE=postgres
DB_DRIVER=org.postgresql.Driver
DB_URL=jdbc:postgresql://<supabase-host>:5432/postgres
DB_SCHEMA=ot_dongmanluntan
DB_SSLMODE=require
DB_USERNAME=<database-user>
DB_PASSWORD=<database-password>
APP_AUTH_SECRET=<change-me>
CORS_ALLOWED_ORIGINS=http://localhost:8088,http://localhost:8080,https://ot-dongmanluntan.pages.dev
LOG_PATH=/tmp/logs
APP_LOG_LEVEL=info

# File upload demo storage
UPLOAD_STATIC_ACCESS_PATH=/attach_files/**
UPLOAD_DISK_PATH=/tmp
UPLOAD_FILE_BASE_PATH=/attach_files/upload

# Frontend runtime config
API_BASE_URL=<cloudbase-run-api-base-url>
